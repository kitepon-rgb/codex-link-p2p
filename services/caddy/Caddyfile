# codex-link-p2p Caddy config.
#
# 役割:
#   - codex-link-p2p.kitepon.dynv6.net  HTTPS + WSS を内部 relay:3000 に reverse-proxy
#   - 同ホスト名向けに ACME (Let's Encrypt) で cert を取得し、coturn が共有
#     volume 経由で同じ cert / key を読みに行く (TURNS 用).
#
# ACME 発行物の path (Docker volume `caddy_data` 内):
#   /data/caddy/certificates/acme-v02.api.letsencrypt.org-directory/<DOMAIN>/<DOMAIN>.{crt,key}

{
	# サーバ管理者宛のメール (Let's Encrypt 通知用).
	email kitepon@gmail.com
}

codex-link-p2p.kitepon.dynv6.net {
	encode zstd gzip

	# WebSocket 用 upgrade ヘッダーをそのまま通す.
	@websocket {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @websocket relay:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}

	# 通常 HTTP リクエスト (health, host-bootstrap, etc.).
	reverse_proxy relay:3000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
	}

	# 軽い security headers.
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format json
	}
}
