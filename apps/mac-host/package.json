{
  "name": "@codex-link/host",
  "version": "0.1.0",
  "description": "Codex Link Host — runs on Mac/Win, brokers iPhone ⇄ local Codex over WebRTC DataChannel.",
  "private": false,
  "type": "module",
  "bin": {
    "codex-link-host": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "build": "tsc -p tsconfig.build.json && chmod +x dist/cli.js",
    "start": "tsx src/cli.ts",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "keywords": [
    "codex",
    "webrtc",
    "iphone",
    "remote",
    "rendezvous"
  ],
  "license": "MIT",
  "dependencies": {
    "@codex-link/protocol": "workspace:^",
    "node-datachannel": "^0.27",
    "qrcode-terminal": "^0.12.0",
    "ws": "^8"
  },
  "devDependencies": {
    "@codex-link/relay": "workspace:^",
    "@types/node": "^20",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
