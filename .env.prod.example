# codex-link-p2p — 本番デプロイ用環境変数テンプレート.
#
# 使い方: 本番サーバーで `cp .env.prod.example .env` してから値を埋める.
# 中身は秘密 (TURN secret / bootstrap token). 絶対に commit しない.

# ===== Relay 公開 URL (Mac Host / iPhone がアクセスする URL) =====
CODEX_LINK_RELAY_URL=https://codex-link.kitepon.dynv6.net

# ===== Host bootstrap token =====
# Mac Host が `codex-link-host init` で提示する共通秘密.
# `openssl rand -hex 32` で生成.
CODEX_LINK_HOST_BOOTSTRAP_TOKEN=__REPLACE_ME__

# ===== TURN shared secret =====
# Relay (ephemeral credential 発行) と coturn (verify) の両方で同じ値を使う.
# `openssl rand -hex 32` で生成.
TURN_SHARED_SECRET=__REPLACE_ME__

# ===== TURN realm =====
TURN_REALM=codex-link-p2p

# ===== TURN URLs (Mac Host / iPhone に配る ICE servers) =====
# stun は Google public. turn / turns はこの本番サーバーの coturn を指す.
TURN_URLS=stun:stun.l.google.com:19302,turn:codex-link-turn.kitepon.dynv6.net:3478,turns:codex-link-turn.kitepon.dynv6.net:5349

# ===== TURN credential TTL =====
TURN_CREDENTIAL_TTL_SEC=300

# ===== rate / size limits (デフォルトで安全) =====
MAX_HTTP_BODY_BYTES=65536
MAX_WS_PAYLOAD_BYTES=131072
PENDING_SIGNAL_TTL_MS=30000
PAIRING_CODE_TTL_MS=600000
RATE_TURN_CREDENTIAL_PER_MINUTE=30
RATE_SIGNAL_FORWARD_PER_MINUTE=600
RATE_PAIRING_CREATE_PER_MINUTE=10
